{
  "name": "@private-markets/avm",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "compile": "aztec-nargo compile",
    "postprocess": "aztec-postprocess-contract",
    "codegen": "aztec codegen target --outdir artifacts --force",
    "build": "npm run compile && npm run postprocess && npm run codegen",
    "pxe:check": "./scripts/check-pxe.sh",
    "pxe:testnet": "./scripts/start-pxe-testnet.sh",
    "pxe:stop": "./scripts/stop-pxe.sh",
    "sandbox:start": "./scripts/start-pxe-sandbox.sh",
    "sandbox:stop": "./scripts/stop-pxe.sh",
    "deploy:token": "node --import tsx/esm scripts/deploy_token.ts",
    "deploy:token:sandbox": "PXE_URL=http://localhost:8080 node --import tsx/esm scripts/deploy_token.ts",
    "deploy:vault": "node --import tsx/esm scripts/deploy_vault.ts",
    "deploy:vault:sandbox": "PXE_URL=http://localhost:8080 node --import tsx/esm scripts/deploy_vault.ts",
    "mint:tokens": "node --import tsx/esm scripts/mint_tokens.ts",
    "mint:tokens:sandbox": "NODE_URL=http://localhost:8080 node --import tsx/esm scripts/mint_tokens.ts",
    "place:bet": "node --import tsx/esm scripts/place_bet.ts",
    "place:bet:sandbox": "NODE_URL=http://localhost:8080 node --import tsx/esm scripts/place_bet.ts",
    "call:bet": "node --import tsx/esm scripts/call_bet.ts",
    "mint:azguard": "node --import tsx/esm scripts/mint_to_azguard.ts",
    "check:accounts": "node --import tsx/esm scripts/check_accounts.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "dependencies": {
    "@aztec/accounts": "^2.0.3",
    "@aztec/aztec.js": "^2.0.3",
    "@aztec/noir-contracts.js": "^2.0.3",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
