{
  "name": "private-markets",
  "version": "1.0.0",
  "description": "**Foundry is a blazing fast, portable and modular toolkit for Ethereum application development written in Rust.**",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "npm run dev --workspace=packages/frontend",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "build": "npm run build --workspace=packages/frontend",
    "build:frontend": "npm run build --workspace=packages/frontend",
    "start": "npm run start --workspace=packages/frontend",
    "start:frontend": "npm run start --workspace=packages/frontend",
    "avm:deploy:token": "npm run deploy:token --workspace=packages/avm",
    "avm:deploy:vault": "npm run deploy:vault --workspace=packages/avm",
    "avm:call:bet": "npm run call:bet --workspace=packages/avm",
    "evm:deploy:local": "cd packages/evm && source .env && forge script script/DeployPredictionMarket.s.sol:DeployPredictionMarket --rpc-url $ANVIL_RPC_URL --private-key $ANVIL_PRIVATE_KEY --broadcast",
    "evm:deploy:testnet": "cd packages/evm && source .env && forge script script/DeployPredictionMarket.s.sol:DeployPredictionMarket --rpc-url $ARBITRUM_SEPOLIA_RPC_URL --private-key $TESTNET_PRIVATE_KEY --broadcast --verify",
    "evm:deploy:testnet:no-verify": "cd packages/evm && source .env && forge script script/DeployPredictionMarket.s.sol:DeployPredictionMarket --rpc-url $ARBITRUM_SEPOLIA_RPC_URL --private-key $TESTNET_PRIVATE_KEY --broadcast",
    "evm:mint:testnet": "cd packages/evm && source .env && forge script script/MintTokens.s.sol:MintTokens --rpc-url $ARBITRUM_SEPOLIA_RPC_URL --private-key $TESTNET_PRIVATE_KEY --broadcast",
    "evm:create-market:testnet": "cd packages/evm && source .env && forge script script/CreateMarket.s.sol:CreateMarket --rpc-url $ARBITRUM_SEPOLIA_RPC_URL --private-key $TESTNET_PRIVATE_KEY --broadcast",
    "evm:build": "cd packages/evm && forge build",
    "evm:test": "cd packages/evm && forge test",
    "e2e:test": "npm run test --workspace=packages/e2e-cross-chain",
    "e2e:test:watch": "npm run test:watch --workspace=packages/e2e-cross-chain",
    "e2e:setup": "npm run setup --workspace=packages/e2e-cross-chain"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "packages/*"
  ]
}